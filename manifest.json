{
  "manifest_version": 3,
  "name": "CiteBeat",
  "description": "听见你引用的节拍：定时获取 Google Scholar / Semantic Scholar 总引用数，查看本周期内引用增长的论文。",
  "version": "0.1.0",
  "permissions": [
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "https://scholar.google.com/*",
    "https://api.semanticscholar.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "CiteBeat",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
